AZMON_TELEGRAM_BOT_TOKEN=123456:replace-me
AZMON_TELEGRAM_CHAT_ID=123456789
AZMON_MONITORED_SEQUENCERS=0x5b1330befeda74a64bc9c0adc8aaef2ef94b31d7,0x4320c1f83be7fab74288bdabc1541caeec22ab38

AZMON_RPC_URL=http://localhost:8545
AZMON_ROLLUP_ADDRESS=0xAe2001f7e21d5EcABf6234E9FDd1E76F50F74962
AZMON_DOCKER_CONTAINER=aztec-sequencer
AZMON_STATE_DIR=$HOME/azmon/state
AZMON_POLL_INTERVAL_SEC=10
AZMON_LOG_LOOKBACK_SEC=20
AZMON_LOG_ALERT_LEVELS=warn,error,fatal
AZMON_DUTY_INFO=false
AZMON_PROPOSAL_GRACE_SEC=120
AZMON_BLOCK_CONFIRMATIONS=2
AZMON_ALERT_COOLDOWN_SEC=900
AZMON_DRY_RUN=false
AZMON_DEBUG=false

